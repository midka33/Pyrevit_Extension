<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Combined PDF" Width="620" Height="760"
        WindowStartupLocation="CenterScreen" Background="#F7F6F4">
  <Window.Resources>
    <SolidColorBrush x:Key="Accent" Color="#8B3A3A"/>
    <SolidColorBrush x:Key="Surface" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Border" Color="#DDD8D2"/>
    <SolidColorBrush x:Key="Muted" Color="#77716C"/>
    <Style x:Key="Btn" TargetType="Button">
      <Setter Property="Padding" Value="10,6"/><Setter Property="Margin" Value="2"/>
      <Setter Property="Background" Value="{StaticResource Surface}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
    </Style>
    <Style x:Key="Primary" TargetType="Button" BasedOn="{StaticResource Btn}">
      <Setter Property="Background" Value="{StaticResource Accent}"/><Setter Property="Foreground" Value="White"/>
    </Style>
    <Style x:Key="Input" TargetType="TextBox">
      <Setter Property="Padding" Value="7,5"/><Setter Property="BorderBrush" Value="{StaticResource Border}"/>
    </Style>
  </Window.Resources>
  <Grid>
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,14">
      <DockPanel><TextBlock Text="Export Combined PDF" FontSize="15" FontWeight="SemiBold"/><TextBlock DockPanel.Dock="Right" Text="TAA ARCHI" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/></DockPanel>
    </Border>
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
      <StackPanel>
        <TextBlock Text="1   SHEET SELECTION" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <ComboBox x:Name="cb_sheet_sets" Grid.Column="0" Margin="0,0,6,0" SelectionChanged="sheet_set_changed"/>
          <Button Grid.Column="1" Content="Save Set" Click="save_sheet_set_click" Style="{StaticResource Btn}"/>
          <Button Grid.Column="2" Content="Delete" Click="delete_sheet_set_click" Style="{StaticResource Btn}"/>
        </Grid>
        <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="4"><ListBox x:Name="lb_sheets" Height="180" BorderThickness="0">
          <ListBox.ItemTemplate><DataTemplate><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Checked="sheet_checked" Unchecked="sheet_checked" Padding="4"><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding Number}" Width="80" FontWeight="SemiBold"/><TextBlock Text="{Binding Name}" Foreground="{StaticResource Muted}"/></StackPanel></CheckBox></DataTemplate></ListBox.ItemTemplate>
        </ListBox></Border>
        <DockPanel Margin="0,5,0,20"><TextBlock x:Name="txt_sheet_count" Foreground="{StaticResource Muted}"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="All" Click="select_all_click" Style="{StaticResource Btn}"/><Button Content="None" Click="select_none_click" Style="{StaticResource Btn}"/></StackPanel></DockPanel>

        <TextBlock Text="2   FILENAME PARAMETERS" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
        <TextBlock Text="Click parameters in the order you want them in the filename." Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,6"/>
        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <ComboBox x:Name="cb_rules" Grid.Column="0" Margin="0,0,6,0" SelectionChanged="rule_changed"/>
          <Button Grid.Column="1" Content="Save Rule" Click="save_rule_click" Style="{StaticResource Btn}"/>
          <Button Grid.Column="2" Content="Delete" Click="delete_rule_click" Style="{StaticResource Btn}"/>
        </Grid>
        <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="4"><ListBox x:Name="lb_params" Height="130" BorderThickness="0">
          <ListBox.ItemTemplate><DataTemplate><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Checked="param_checked" Unchecked="param_checked" Padding="4"><TextBlock Text="{Binding Name}"/></CheckBox></DataTemplate></ListBox.ItemTemplate>
        </ListBox></Border>
        <Grid Margin="0,10,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="65"/></Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,6,0"><TextBlock Text="PREFIX" FontSize="10" Foreground="{StaticResource Muted}"/><TextBox x:Name="txt_prefix" Style="{StaticResource Input}" TextChanged="update_preview_event"/></StackPanel>
          <StackPanel Grid.Column="1" Margin="0,0,6,0"><TextBlock Text="SUFFIX" FontSize="10" Foreground="{StaticResource Muted}"/><TextBox x:Name="txt_suffix" Style="{StaticResource Input}" TextChanged="update_preview_event"/></StackPanel>
          <StackPanel Grid.Column="2"><TextBlock Text="SEP" FontSize="10" Foreground="{StaticResource Muted}"/><TextBox x:Name="txt_separator" Text="_" Style="{StaticResource Input}" TextAlignment="Center" TextChanged="update_preview_event"/></StackPanel>
        </Grid>
        <Border Background="#292624" CornerRadius="5" Padding="12" Margin="0,0,0,20"><StackPanel><TextBlock Text="FILENAME PREVIEW" Foreground="#A9A19A" FontSize="10"/><TextBlock x:Name="txt_preview" Foreground="#F0D5BD" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Border>

        <TextBlock Text="3   QUALITY SETTINGS" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
        <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,6,0"><TextBlock Text="DPI" FontSize="10" Foreground="{StaticResource Muted}"/><ComboBox x:Name="cb_quality"><ComboBoxItem Content="72 DPI (Draft)"/><ComboBoxItem Content="144 DPI (Screen)"/><ComboBoxItem Content="300 DPI (Print)" IsSelected="True"/><ComboBoxItem Content="600 DPI (High Detail)"/></ComboBox></StackPanel>
          <StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Text="COLOR" FontSize="10" Foreground="{StaticResource Muted}"/><ComboBox x:Name="cb_color"><ComboBoxItem Content="Color" IsSelected="True"/><ComboBoxItem Content="Grayscale"/><ComboBoxItem Content="Black and White"/></ComboBox></StackPanel>
        </Grid>
        <CheckBox x:Name="chk_vector" IsChecked="True" Content="Vector processing, lighter files and clean linework" Margin="0,0,0,12"/>
      </StackPanel>
    </ScrollViewer>
    <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="20,12"><DockPanel>
      <TextBlock x:Name="txt_folder" Text="No folder selected" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Browse..." Click="browse_click" Style="{StaticResource Btn}"/><Button Content="Cancel" Click="cancel_click" Style="{StaticResource Btn}"/><Button Content="Export PDF" Click="export_click" Style="{StaticResource Primary}"/></StackPanel>
    </DockPanel></Border>
  </Grid>
</Window>